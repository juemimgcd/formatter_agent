APP_NAME=Resume Search Agent
APP_ENV=dev
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/rebuild_agent
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_EXPIRES_SECONDS=300
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=0
CANDIDATE_CHUNK_TIMEOUT_SECONDS=0
STRUCTURED_STAGE_TIMEOUT_SECONDS=0
SEARCH_PROVIDER=auto
SEARCH_TIMEOUT_SECONDS=12
SEARCH_PROXY_URL=
SEARCH_TRUST_ENV=true
SEARCH_FAILURE_LLM_FALLBACK_ENABLED=true
SEARCH_RESULT_LIMIT=8
SEARCH_REGION=cn-zh
